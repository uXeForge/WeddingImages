<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Wedding FAQ</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link
    href="https://fonts.googleapis.com/css2?family=Noto+Serif+Toto:wght@400;500;600;700&family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap"
    rel="stylesheet">
  <style>
    *,
    *::before,
    *::after {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    :root {
      --sky: #9bceec;
      --gold-muted: #baa885;
      --sage: #80a48c;
      --forest: #6d8e79;
      --earth: #816e4e;
      --sand: #c4ab87;
      --peach: #f4c7ab;
      --terracotta: #ce9c7e;
      --cream: #faf6f1;
      --dark: #3a3530;
      --text: #4a4540;
      --text-light: #7a756e;
      --text-black: #000000;
      --rose: #d13a48;
    }

    html,
    body {
      scroll-behavior: smooth;
      -ms-overflow-style: none;
      scrollbar-width: none;
      height: auto;
      min-height: 0;
      overflow: hidden !important;
      overscroll-behavior: none;
    }

    *::-webkit-scrollbar,
    html::-webkit-scrollbar,
    body::-webkit-scrollbar {
      width: 0;
      height: 0;
      display: none;
    }

    body {
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-weight: 300;
      background: transparent;
      color: var(--text);
      line-height: 1.7;
      overflow: hidden !important;
      overscroll-behavior: none;
      position: relative;
      width: 100%;
    }

    /* ——— CONTAINER ——— */
    .faq-container {
      max-width: 1280px;
      margin: 0 auto;
      padding: 3rem 2.5rem 4rem;
    }

    /* ——— FAQ SECTION CARD ——— */
    .faq-section {
      display: flex;
      flex-direction: row-reverse;
      align-items: center;
      gap: 3rem;
      padding: 2.5rem 0;
      border-bottom: 1px solid rgba(186, 168, 133, 0.2);
      opacity: 0;
      transform: translateY(30px);
      transition: all 0.7s cubic-bezier(0.16, 1, 0.3, 1);
    }

    .faq-section.visible {
      opacity: 1;
      transform: translateY(0);
    }

    .faq-section:last-child {
      border-bottom: none;
    }

    .faq-section.reverse {
      flex-direction: row;
    }

    /* ——— TEXT SIDE ——— */
    .faq-text {
      flex: 1;
      min-width: 0;
    }

    .faq-text h2 {
      font-family: 'Noto Serif Toto';
      font-size: 34px;
      color: var(--forest);
      margin-bottom: 0.8rem;
      font-weight: bold;
      letter-spacing: -0.01em;
      line-height: 1.3;
    }

    .faq-text p {
      font-size: 12pt;
      color: var(--text-black);
      line-height: 1.75;
    }

    .faq-text a {
      color: var(--forest);
      text-decoration: underline;
      text-underline-offset: 3px;
      transition: color 0.3s ease;
    }

    .faq-text a:hover {
      color: var(--earth);
    }

    /* ——— ILLUSTRATION SIDE ——— */
    .faq-illustration {
      flex: 0 0 200px;
      display: flex;
      align-items: center;
    }

    .faq-img {
      width: 100%;
      max-width: 200px;
      height: auto;
      object-fit: contain;
    }

    /* Two images side by side */
    .faq-img-duo {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 10px;
      max-width: 200px;
    }

    .faq-img-duo img {
      width: 100%;
      height: auto;
      object-fit: contain;
      border-radius: 8px;
    }

    /* ——— DUAL COLUMN SECTION ——— */
    .faq-dual {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 2.5rem;
      padding: 2.5rem 0;
      border-bottom: 1px solid rgba(186, 168, 133, 0.2);
      opacity: 0;
      transform: translateY(30px);
      transition: all 0.7s cubic-bezier(0.16, 1, 0.3, 1);
    }

    .faq-dual.visible {
      opacity: 1;
      transform: translateY(0);
    }

    .faq-dual-item h2 {
      font-family: 'Noto Serif Toto', serif;
      font-size: 1.7rem;
      color: var(--forest);
      margin-bottom: 0.8rem;
      font-weight: 700;
      letter-spacing: -0.01em;
      line-height: 1.3;
    }

    .faq-dual-item p {
      font-size: 12pt;
      color: var(--text-black);
      line-height: 1.75;
    }

    /* ——— COLOR DOTS (hexagon layout) ——— */
    .color-dots {
      position: relative;
      width: 200px;
      height: 200px;
    }

    .color-dot {
      position: absolute;
      width: 55px;
      height: 55px;
      margin-left: -27.5px;
      margin-top: -27.5px;
      border-radius: 50%;
      box-shadow: 0 4px 14px rgba(0, 0, 0, 0.08);
      transition: transform 0.3s ease, box-shadow 0.3s ease;
      cursor: pointer;
    }

    .color-dot:hover {
      transform: scale(1.15) translateY(-4px);
      box-shadow: 0 8px 24px rgba(0, 0, 0, 0.15);
      z-index: 10;
    }

    /* HEXAGON LAYOUT */
    .color-dot:nth-child(1) {
      left: 50%;
      top: 50%;
      z-index: 7;
    }

    .color-dot:nth-child(2) {
      left: 50%;
      top: calc(50% - 62px);
      z-index: 6;
    }

    .color-dot:nth-child(3) {
      left: calc(50% + 54px);
      top: calc(50% - 31px);
      z-index: 5;
    }

    .color-dot:nth-child(4) {
      left: calc(50% + 54px);
      top: calc(50% + 31px);
      z-index: 4;
    }

    .color-dot:nth-child(5) {
      left: 50%;
      top: calc(50% + 62px);
      z-index: 3;
    }

    .color-dot:nth-child(6) {
      left: calc(50% - 54px);
      top: calc(50% + 31px);
      z-index: 2;
    }

    .color-dot:nth-child(7) {
      left: calc(50% - 54px);
      top: calc(50% - 31px);
      z-index: 1;
    }

    /* ——— TABLET ——— */
    @media (max-width: 900px) {
      .faq-container {
        padding: 2rem 1.5rem 3rem;
      }

      .faq-section {
        gap: 2rem;
      }

      .faq-illustration {
        flex: 0 0 150px;
      }

      .faq-img {
        max-width: 150px;
      }

      .faq-text h2 {
        font-size: 1.7rem;
      }
    }

    /* ——— MOBILE ——— */
    @media (max-width: 600px) {
      .faq-container {
        padding: 1rem 1rem 2rem;
      }

      .faq-section,
      .faq-section.reverse {
        display: flow-root !important;
        padding: 1.2rem 0;
      }

      .faq-illustration {
        float: left;
        margin: 0.3rem 0.8rem 0.2rem 0;
        width: auto;
      }

      .faq-section .faq-text h2 {
        text-align: left;
        margin-bottom: 0.15rem;
        font-size: 1.4rem;
        line-height: 1.2;
      }

      .faq-section .faq-text p {
        text-align: left;
        font-size: 12pt;
        line-height: 1.65;
        margin: 0;
      }

      .faq-img {
        max-width: 100px;
      }

      .faq-img-duo {
        max-width: 100px;
        gap: 6px;
      }

      .faq-dual {
        grid-template-columns: 1fr;
        gap: 1.2rem;
        padding: 1.2rem 0;
      }

      .faq-dual-item h2 {
        font-size: 1.3rem;
        text-align: left;
      }

      .faq-dual-item p {
        font-size: 0.85rem;
        text-align: left;
      }

      .color-dots {
        width: 100px;
        height: 100px;
        margin: 0;
      }

      .color-dot {
        width: 28px;
        height: 28px;
        margin-left: -14px;
        margin-top: -14px;
      }

      .color-dot:nth-child(2) {
        top: calc(50% - 32px);
      }

      .color-dot:nth-child(3) {
        left: calc(50% + 28px);
        top: calc(50% - 16px);
      }

      .color-dot:nth-child(4) {
        left: calc(50% + 28px);
        top: calc(50% + 16px);
      }

      .color-dot:nth-child(5) {
        top: calc(50% + 32px);
      }

      .color-dot:nth-child(6) {
        left: calc(50% - 28px);
        top: calc(50% + 16px);
      }

      .color-dot:nth-child(7) {
        left: calc(50% - 28px);
        top: calc(50% - 16px);
      }
    }
  </style>
</head>

<body>

  <div class="faq-container">

    <!-- 1 · DRESS CODE -->
    <div class="faq-section">
      <div class="faq-illustration">
        <!-- DRESS CODE: Vlož URL obrázku -->
        <img class="faq-img" src="https://r2.image-upload.app/ptImg/Q5eu3Tq7.png" alt="DressCodew.png" />
      </div>
      <div class="faq-text">
        <h2>Dress code</h2>
        <p>We kindly invite you to dress your best for our special day. Think elegant, festive, and comfortable enough
          to celebrate with us all day. Your presence is what matters most, but a touch of style will make the day all
          the more beautiful.</p>
      </div>
    </div>

    <!-- 2 · WEDDING COLORS -->
    <div class="faq-section reverse">
      <div class="faq-illustration">
        <div class="color-dots">
          <div class="color-dot" style="background: #c7b095;" title="Sand"></div>
          <div class="color-dot" style="background: #87a08b;" title="Sage"></div>
          <div class="color-dot" style="background: #9aceeb;" title="Sky"></div>
          <div class="color-dot" style="background: #ffb1b9;" title="Rose"></div>
          <div class="color-dot" style="background: #d13a48;" title="Crimson"></div>
          <div class="color-dot" style="background: #f2c7ae;" title="Peach"></div>
          <div class="color-dot" style="background: #e6d36e;" title="Mustard"></div>
        </div>
      </div>
      <div class="faq-text">
        <h2>Wedding colors</h2>
        <p>For those who enjoy coordinating with the theme, we have chosen a palette of colors that will complement the
          atmosphere of our celebration. While this is entirely optional, you are warmly welcome to incorporate these
          tones into your attire if you wish to match the spirit of the day.</p>
      </div>
    </div>

    <!-- 3 · PLUS-ONE & KIDS (dual column) -->
    <div class="faq-dual">
      <div class="faq-dual-item">
        <h2>Can I bring a plus-one?</h2>
        <p>Due to the nature of our venue and the size of our celebration, we are able to accommodate only those guests
          who are specifically named on the invitation. We hope for your understanding and look forward to celebrating
          together with you.</p>
      </div>
      <div class="faq-dual-item">
        <h2>Are kids invited?</h2>
        <p>To help accommodate the travel and logistics of our international guests, we have made the thoughtful
          decision to extend invitations to children only for those coming from abroad. We hope for your understanding
          as we aim to keep the celebration comfortable and manageable for everyone attending, while supporting those
          who are traveling from further away.</p>
      </div>
    </div>

    <!-- 4 · GIFT REGISTRY -->
    <div class="faq-section">
      <div class="faq-illustration">
        <div class="faq-img-duo">
          <!-- GIFT REGISTRY: Vlož URL obrázku 1 -->
          <img src="https://r2.image-upload.app/ptImg/XUzvbcxy.png" alt="gift.png" />
          <!-- GIFT REGISTRY: Vlož URL obrázku 2 -->
          <img src="https://r2.image-upload.app/ptImg/1bdIQYgx1.png" alt="flowers.png" />
        </div>
      </div>
      <div class="faq-text">
        <h2>Gift registry</h2>
        <p>Your presence at our wedding is truly the greatest gift we could ask for. We kindly request no physical
          gifts or flowers. For those who feel inclined to contribute, a small contribution toward our honeymoon would
          be sincerely appreciated.</p>
      </div>
    </div>

    <!-- 5 · UNPLUGGED CEREMONY -->
    <div class="faq-section reverse">
      <div class="faq-illustration">
        <div class="faq-img-duo">
          <!-- UNPLUGGED CEREMONY: Vlož URL obrázku 1 -->
          <img src="https://r2.image-upload.app/ptImg/zjfYzpWE.png" alt="Phone.png" />
          <!-- UNPLUGGED CEREMONY: Vlož URL obrázku 2 -->
          <img src="https://r2.image-upload.app/ptImg/GRcW3wy6.png" alt="camera.png" />
        </div>
      </div>
      <div class="faq-text">
        <h2>Unplugged Ceremony</h2>
        <p>We kindly invite you to be fully present with us during our ceremony by keeping phones, cameras, and
          devices tucked away. We have arranged for special moments to be captured, and your presence means far more to
          us than any photo. By sharing this time without screens, we can create a more intimate and meaningful
          atmosphere together.</p>
      </div>
    </div>

    <!-- 6 · NO CONFETTI POLICY -->
    <div class="faq-section">
      <div class="faq-illustration">
        <!-- NO CONFETTI: Vlož URL obrázku -->
        <img class="faq-img" src="https://r2.image-upload.app/ptImg/oipw0SbU.png" alt="confetti.png" />
      </div>
      <div class="faq-text">
        <h2>No Confetti Policy</h2>
        <p>To help us care for the venue and its surroundings, we kindly ask that no confetti, rice, fireworks,
          party-poppers, or similar items be thrown during the celebration. We fully appreciate your understanding and
          support in keeping the space clean and enjoyable for everyone.</p>
      </div>
    </div>

    <!-- 7 · WHO CAN I CONTACT? -->
    <div class="faq-section reverse">
      <div class="faq-illustration">
        <!-- CONTACT: Vlož URL obrázku -->
        <img class="faq-img" src="https://r2.image-upload.app/ptImg/104rd8gdf.png" alt="email.png" />
      </div>
      <div class="faq-text">
        <h2>Who can I contact?</h2>
        <p>For any further questions or assistance, please do not hesitate to contact our ceremony masters, Marlon and
          Dominik, who will be pleased to assist you.</p>
        <p style="margin-top: 0.8rem;">They can be reached at
          <a href="mailto:weddingondrejanniecke@gmail.com">weddingondrejanniecke@gmail.com</a>
        </p>
      </div>
    </div>

  </div>

  <script>
    const resizeEmbed = () => {
      const height = Math.ceil(document.documentElement.scrollHeight);

      document.documentElement.style.height = `${height}px`;
      document.body.style.height = `${height}px`;
      document.documentElement.style.maxHeight = `${height}px`;
      document.body.style.maxHeight = `${height}px`;

      if (window.frameElement) {
        const isTouchDevice = window.matchMedia('(pointer: coarse)').matches;

        window.frameElement.style.height = `${height}px`;
        window.frameElement.style.minHeight = `${height}px`;
        window.frameElement.style.overflow = 'hidden';
        window.frameElement.style.pointerEvents = isTouchDevice ? 'none' : 'auto';
        window.frameElement.setAttribute('scrolling', 'no');
      }

      window.parent.postMessage({ type: 'faq-embed-height', height }, '*');
    };

    const obs = new IntersectionObserver((entries) => {
      entries.forEach(e => {
        if (e.isIntersecting) {
          e.target.classList.add('visible');
          obs.unobserve(e.target);
        }
      });
    }, { threshold: 0.12, rootMargin: '0px 0px -40px 0px' });

    document.querySelectorAll('.faq-section, .faq-dual').forEach(el => obs.observe(el));

    window.addEventListener('load', resizeEmbed);
    window.addEventListener('resize', resizeEmbed);
    setTimeout(resizeEmbed, 250);
    setTimeout(resizeEmbed, 1000);
  </script>
</body>

</html>

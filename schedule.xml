<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link
    href="https://fonts.googleapis.com/css2?family=Noto+Serif+Toto:wght@400;500;600;700&family=Plus+Jakarta+Sans:wght@300;400;500;600;700&display=swap"
    rel="stylesheet">
  <style>
    *,
    *::before,
    *::after {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    :root {
      --sky: #9bceec;
      --gold-muted: #baa885;
      --sage: #80a48c;
      --forest: #6d8e79;
      --earth: #816e4e;
      --sand: #c4ab87;
      --peach: #f4c7ab;
      --terracotta: #ce9c7e;
      --cream: #faf6f1;
      --dark: #3a3530;
      --text: #4a4540;
      --text-light: #7a756e;
      --text-black: #000000;
    }

    html,
    body {
      scroll-behavior: smooth;
      -ms-overflow-style: none;
      scrollbar-width: none;
      overflow-y: auto;
    }

    *::-webkit-scrollbar,
    html::-webkit-scrollbar,
    body::-webkit-scrollbar {
      width: 0;
      height: 0;
      display: none;
    }

    body {
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-weight: 300;
      background: transparent;
      color: var(--text);
      line-height: 1.7;
      overflow-x: hidden;
    }

    @keyframes fadeIn {
      from {
        opacity: 0;
        transform: translateY(20px);
      }

      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    .timeline {
      max-width: 1100px;
      margin: 0 auto;
      padding: 2rem 2.5rem 2.5rem;
      position: relative;
    }

    .timeline-line {
      position: absolute;
      left: 50%;
      top: 0;
      bottom: 0;
      width: 2px;
      background: linear-gradient(to bottom, transparent, var(--sand) 3%, var(--sage) 50%, var(--sand) 97%, transparent);
      transform: translateX(-50%);
    }

    .tl-item {
      position: relative;
      display: flex;
      align-items: center;
      margin-bottom: 0.25;
      opacity: 0;
      transform: translateY(30px);
      transition: all 0.7s cubic-bezier(0.16, 1, 0.3, 1);
    }

    /* Pull adjacent items up to interleave them and close the gap between nodes */
    .tl-item+.tl-item {
      margin-top: -40px;
    }

    .tl-item.visible {
      opacity: 1;
      transform: translateY(0);
    }

    .tl-item:nth-child(odd) {
      flex-direction: row;
    }

    .tl-item:nth-child(even) {
      flex-direction: row-reverse;
    }

    .tl-item .side {
      width: calc(50% - 34px);
      display: flex;
    }

    .tl-item:nth-child(odd) .side {
      justify-content: flex-end;
      text-align: right;
    }

    .tl-item:nth-child(even) .side {
      justify-content: flex-start;
      text-align: left;
    }

    .tl-item .spacer {
      width: calc(50% - 34px);
      display: flex;
      justify-content: center;
      align-items: center;
    }

    .tl-item .spacer img {
      max-width: 100px;
      max-height: 100px;
      object-fit: contain;
      opacity: 0.8;
    }

    /* ─── NODE ─── */
    .node {
      position: absolute;
      left: 50%;
      top: 50%;
      transform: translate(-50%, -50%);
      width: 60px;
      height: 60px;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      z-index: 2;
      box-shadow: 0 3px 16px rgba(0, 0, 0, 0.08);
      transition: transform 0.3s ease, box-shadow 0.3s ease;
    }

    .tl-item:hover .node {
      transform: translate(-50%, -50%) scale(1.1);
      box-shadow: 0 5px 24px rgba(0, 0, 0, 0.12);
    }

    .node svg {
      width: 26px;
      height: 26px;
      fill: white;
    }

    .node img {
      width: 55px;
      height: 55px;
      object-fit: contain;
      /* If the image is not white and you want to force it to be white, uncomment below: */
      /* filter: brightness(0) invert(1); */
    }

    /* ─── CARD ─── */
    .card {
      max-width: 440px;
      width: 100%;
      background: rgba(255, 255, 255, 0.7);
      backdrop-filter: blur(10px);
      -webkit-backdrop-filter: blur(10px);
      border: 1px solid rgba(186, 168, 133, 0.2);
      border-radius: 14px;
      padding: 1.5rem 1.8rem;
      transition: transform 0.35s ease, box-shadow 0.35s ease, border-color 0.35s ease;
    }

    .card:hover {
      transform: translateY(-3px);
      box-shadow: 0 10px 35px rgba(129, 110, 78, 0.1);
      border-color: rgba(186, 168, 133, 0.4);
    }

    .time {
      font-family: 'Plus Jakarta Sans', sans-serif;
      font-weight: 800;
      font-size: 1rem;
      color: var(--earth);
      letter-spacing: 0.04em;
      margin-bottom: 0.2rem;
    }

    .card h3 {
      font-family: 'Noto Serif Toto', serif;
      font-weight: 800;
      font-size: 1.8rem;
      letter-spacing: 0.03em;
      margin-bottom: 0.4rem;
    }

    .card p {
      font-size: 1rem;
      color: var(--text-black);
      line-height: 1.65;
    }

    /* ─── PER-ITEM COLORS ─── */
    /* Note: 4 siblings before first tl-item (timeline-line + 3 leaves) */
    .tl-item:nth-child(5) .node {
      background: white;
    }

    .tl-item:nth-child(5) .card h3 {
      color: var(--forest);
    }

    .tl-item:nth-child(6) .node {
      background: white;
    }

    .tl-item:nth-child(6) .card h3 {
      color: var(--forest);
    }

    .tl-item:nth-child(7) .node {
      background: white;
    }

    .tl-item:nth-child(7) .card h3 {
      color: var(--forest);
    }

    .tl-item:nth-child(8) .node {
      background: white;
    }

    .tl-item:nth-child(8) .card h3 {
      color: var(--forest);
    }

    .tl-item:nth-child(9) .node {
      background: white;
    }

    .tl-item:nth-child(9) .card h3 {
      color: var(--forest);
    }

    .tl-item:nth-child(10) .node {
      background: white;
    }

    .tl-item:nth-child(10) .card h3 {
      color: var(--forest);
    }

    .tl-item:nth-child(11) .node {
      background: white;
    }

    .tl-item:nth-child(11) .card h3 {
      color: var(--forest);
    }


    .tl-item:hover .dino {
      opacity: 0.35;
    }

    /* ─── WEDDING COLORS ─── */
    .wedding-colors-section {
      max-width: 1100px;
      margin: 4rem auto 2rem;
      padding: 0 2.5rem;
      display: flex;
      align-items: center;
      gap: 5rem;
    }

    .colors-text {
      flex: 1;
      opacity: 0;
      transform: translateX(-30px);
      transition: all 0.8s cubic-bezier(0.16, 1, 0.3, 1);
    }

    .colors-text.visible {
      opacity: 1;
      transform: translateX(0);
    }

    .colors-text h2 {
      font-family: 'Noto Serif Toto', serif;
      font-size: 3.2rem;
      color: var(--forest);
      margin-bottom: 1.2rem;
      font-weight: 700;
      letter-spacing: -0.02em;
    }

    .colors-text p {
      font-size: 1.05rem;
      color: var(--text);
      line-height: 1.8;
    }

    .colors-palette {
      flex: 1;
      position: relative;
      height: 260px;
      min-width: 260px;
      display: flex;
      justify-content: center;
      align-items: center;
    }

    .color-swatch {
      position: absolute;
      width: 75px;
      height: 75px;
      margin-left: -37.5px;
      margin-top: -37.5px;
      border-radius: 50%;
      box-shadow: 0 8px 24px rgba(0, 0, 0, 0.08);
      transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1);
      cursor: pointer;
      opacity: 0;
      transform: scale(0.5) translateY(20px);
    }

    /* HEXAGON LAYOUT */
    .color-swatch:nth-child(1) {
      left: 50%;
      top: 50%;
      z-index: 7;
    }

    .color-swatch:nth-child(2) {
      left: 50%;
      top: calc(50% - 83px);
      z-index: 6;
    }

    .color-swatch:nth-child(3) {
      left: calc(50% + 72px);
      top: calc(50% - 41.5px);
      z-index: 5;
    }

    .color-swatch:nth-child(4) {
      left: calc(50% + 72px);
      top: calc(50% + 41.5px);
      z-index: 4;
    }

    .color-swatch:nth-child(5) {
      left: 50%;
      top: calc(50% + 83px);
      z-index: 3;
    }

    .color-swatch:nth-child(6) {
      left: calc(50% - 72px);
      top: calc(50% + 41.5px);
      z-index: 2;
    }

    .color-swatch:nth-child(7) {
      left: calc(50% - 72px);
      top: calc(50% - 41.5px);
      z-index: 1;
    }

    .color-swatch.visible {
      opacity: 1;
      transform: scale(1) translateY(0);
    }

    .color-swatch:hover {
      transform: scale(1.15) translateY(-8px);
      box-shadow: 0 15px 35px rgba(0, 0, 0, 0.15);
      z-index: 10 !important;
    }

    /* Tooltip on hover */
    .color-swatch::after {
      content: attr(data-color);
      position: absolute;
      bottom: -40px;
      left: 50%;
      transform: translateX(-50%);
      background: var(--dark);
      color: white;
      font-size: 0.85rem;
      padding: 6px 14px;
      border-radius: 20px;
      opacity: 0;
      visibility: hidden;
      transition: all 0.3s ease;
      white-space: nowrap;
      pointer-events: none;
      font-weight: 500;
    }

    .color-swatch:hover::after {
      opacity: 1;
      visibility: visible;
      bottom: -45px;
    }



    /* ─── LEAF DECORATIONS ─── */
    .leaf {
      position: absolute;
      opacity: 0.05;
      pointer-events: none;
    }

    .leaf svg {
      fill: var(--forest);
    }

    .leaf-1 {
      top: 12%;
      left: 4%;
      transform: rotate(-30deg);
    }

    .leaf-2 {
      top: 50%;
      right: 2%;
      transform: rotate(15deg) scaleX(-1);
    }

    .leaf-3 {
      top: 82%;
      left: 6%;
      transform: rotate(-50deg);
    }

    /* ─── TABLET ─── */
    @media (max-width: 900px) {
      .timeline {
        max-width: 100%;
        padding: 1.5rem 1.5rem 2rem;
      }

      .card {
        padding: 1.4rem 1.5rem;
      }

      .time {
        font-size: 0.9rem;
      }

      .card h3 {
        font-size: 1.6rem;
      }

      .card p {
        font-size: 0.9rem;
      }

      .node {
        width: 50px;
        height: 50px;
      }

      .node svg {
        width: 22px;
        height: 22px;
      }

      .wedding-colors-section {
        flex-direction: column;
        text-align: center;
        gap: 3rem;
        padding: 0 1.5rem;
        margin: 2rem auto 3rem;
      }

      .colors-text {
        transform: translateY(30px);
      }

      .colors-text.visible {
        transform: translateY(0);
      }

      .colors-text h2 {
        font-size: 2.5rem;
      }

      .colors-palette {
        justify-content: center;
      }
    }

    /* ─── MOBILE ─── */
    @media (max-width: 600px) {
      .timeline {
        padding: 1rem 0.5rem 1.5rem;
        overflow: visible;
      }

      .timeline-line {
        left: 28px;
      }

      .tl-item,
      .tl-item:nth-child(odd),
      .tl-item:nth-child(even) {
        flex-direction: row;
        align-items: flex-start;
        padding-left: 56px;
        margin-bottom: 2rem;
        margin-top: 0;
      }

      .tl-item .side {
        width: 100%;
        text-align: left !important;
      }

      .tl-item .spacer {
        display: none;
      }

      .node {
        position: absolute;
        left: calc(28px - 0.5rem);
        top: 50%;
        transform: translate(-50%, -50%);
        width: 42px;
        height: 42px;
      }

      .tl-item:hover .node {
        transform: translate(-50%, -50%) scale(1.08);
      }

      .node svg {
        width: 18px;
        height: 18px;
      }

      .card {
        padding: 1.2rem 1.2rem;
        border-radius: 12px;
      }

      .time {
        font-size: 0.85rem;
      }

      .card h3 {
        font-size: 1.2rem;
        margin-bottom: 0.3rem;
      }

      .card p {
        font-size: 0.85rem;
        line-height: 1.55;
      }

      /* Hide leaf decorations on mobile */
      .leaf {
        display: none;
        color: #ffffff;
      }

      .colors-palette {
        height: 200px;
        min-width: 200px;
      }

      .color-swatch {
        width: 60px;
        height: 60px;
        margin-left: -30px;
        margin-top: -30px;
      }

      .color-swatch:nth-child(2) {
        top: calc(50% - 66px);
      }

      .color-swatch:nth-child(3) {
        left: calc(50% + 57px);
        top: calc(50% - 33px);
      }

      .color-swatch:nth-child(4) {
        left: calc(50% + 57px);
        top: calc(50% + 33px);
      }

      .color-swatch:nth-child(5) {
        top: calc(50% + 66px);
      }

      .color-swatch:nth-child(6) {
        left: calc(50% - 57px);
        top: calc(50% + 33px);
      }

      .color-swatch:nth-child(7) {
        left: calc(50% - 57px);
        top: calc(50% - 33px);
      }
    }
  </style>
</head>

<body>
  <!-- TIMELINE -->
  <section class="timeline">
    <div class="timeline-line"></div>

    <div class="leaf leaf-1"><svg width="0" height="0" viewBox="0 0 24 24">
        <path
          d="M17,8C8,10 5.9,16.17 3.82,21.34L5.71,22L6.66,19.7C7.14,19.87 7.64,20 8,20C19,20 22,3 22,3C21,5 14,5.25 9,6.25C4,7.25 2,11.5 2,13.5C2,15.5 3.75,17.25 3.75,17.25C7,8 17,8 17,8Z" />
      </svg></div>
    <div class="leaf leaf-2"><svg width="0" height="0" viewBox="0 0 24 24">
        <path
          d="M17,8C8,10 5.9,16.17 3.82,21.34L5.71,22L6.66,19.7C7.14,19.87 7.64,20 8,20C19,20 22,3 22,3C21,5 14,5.25 9,6.25C4,7.25 2,11.5 2,13.5C2,15.5 3.75,17.25 3.75,17.25C7,8 17,8 17,8Z" />
      </svg></div>
    <div class="leaf leaf-3"><svg width="0" height="0" viewBox="0 0 24 24">
        <path
          d="M17,8C8,10 5.9,16.17 3.82,21.34L5.71,22L6.66,19.7C7.14,19.87 7.64,20 8,20C19,20 22,3 22,3C21,5 14,5.25 9,6.25C4,7.25 2,11.5 2,13.5C2,15.5 3.75,17.25 3.75,17.25C7,8 17,8 17,8Z" />
      </svg></div>

    <!-- 1 · Arrival & Welcome -->
    <div class="tl-item">
      <div class="side">
        <div class="card">
          <div class="time">13:00 - 14:00</div>
          <h3>Arrival &amp; welcome</h3>
          <p>Guests are welcome to arrive and settle in at their own pace as the venue opens. <br> We look forward to
            joining you shortly.</p>
        </div>
      </div>
      <div class="node">
        <!-- Vlož sem cestu k svojmu obrázku (napr. "images/auto.png") -->
        <img src="https://r2.image-upload.app/ptImg/U29KcTSU.png" alt="arrival.png" />
      </div>
      <div class="spacer">
        <img src="https://r2.image-upload.app/ptImg/U9HsaWsO.png" alt="downleft.png" />
      </div>
    </div>

    <!-- 2 · The Ceremony -->
    <div class="tl-item">
      <div class="side">
        <div class="card">
          <div class="time">14:30</div>
          <h3>The ceremony</h3>
          <p>Join us as we exchange our vows and officially begin this new chapter together.</p>
        </div>
      </div>
      <div class="node">
        <img src="https://r2.image-upload.app/ptImg/aO3BC56i.png" alt="ceremony.png" />
      </div>
    </div>

    <!-- 3 · Cake & Toasts -->
    <div class="tl-item">
      <div class="side">
        <div class="card">
          <div class="time">15:30</div>
          <h3>Cake &amp; toasts</h3>
          <p>A moment to raise a glass, share a few words, and enjoy something sweet together.</p>
        </div>
      </div>
      <div class="node">
        <img src="https://r2.image-upload.app/ptImg/2WYT0YIy.png" alt="cake.png" />
      </div>
    </div>

    <!-- 4 · Pictures & Memories -->
    <div class="tl-item">
      <div class="side">
        <div class="card">
          <div class="time">16:00</div>
          <h3>Pictures &amp; memories</h3>
          <p>Take this time to capture photos with us and create memories we will cherish for years to come.</p>
        </div>
      </div>
      <div class="node">
        <!-- Vlož sem cestu k svojmu obrázku (napr. "images/auto.png") -->
        <img src="https://r2.image-upload.app/ptImg/zOg8MpB9.png" alt="memories.png" />
      </div>
      <div class="spacer">
        <img src="https://r2.image-upload.app/ptImg/1fNjhYBFl.png" alt="downright.png" />
      </div>
    </div>

    <!-- 5 · Dinner -->
    <div class="tl-item">
      <div class="side">
        <div class="card">
          <div class="time">17:00</div>
          <h3>Dinner</h3>
          <p>Please join us for a shared meal as we relax, connect, and enjoy the evening together.</p>
        </div>
      </div>
      <div class="node">
        <!-- Vlož sem cestu k svojmu obrázku (napr. "images/auto.png") -->
        <img src="https://r2.image-upload.app/ptImg/ZgKpnoJu.png" alt="DINNER.png" />
      </div>
    </div>

    <!-- 6 · Celebration -->
    <div class="tl-item">
      <div class="side">
        <div class="card">
          <div class="time">19:30</div>
          <h3>Celebration</h3>
          <p>As the evening unfolds, we invite you to enjoy a cozy atmosphere filled with music, drinks, and good
            company.</p>
        </div>
      </div>
      <div class="node">
        <!-- Vlož sem cestu k svojmu obrázku (napr. "images/auto.png") -->
        <img src="https://r2.image-upload.app/ptImg/LGh7VZ0B.png" alt="celebration.png" />
      </div>
    </div>

    <!-- 7 · Last Call -->
    <div class="tl-item">
      <div class="side">
        <div class="card">
          <div class="time">23:30</div>
          <h3>Last call</h3>
          <p>As the night comes to a close, we'll share a final moment together before saying our goodbyes.</p>
        </div>
      </div>
      <div class="node">
        <img src="https://r2.image-upload.app/ptImg/LZ6qNqG9.png" alt="car bey.png" />
      </div>
      <div class="spacer">
        <img src="https://r2.image-upload.app/ptImg/U9HsaWsO.png" alt="downleft.png" />
      </div>
    </div>

  </section>

  <script>
    const resizeEmbed = () => {
      const height = Math.ceil(document.documentElement.scrollHeight);

      if (window.frameElement) {
        window.frameElement.style.height = `${height}px`;
        window.frameElement.style.overflow = 'hidden';
        window.frameElement.setAttribute('scrolling', 'no');
      }

      window.parent.postMessage({ type: 'schedule-embed-height', height }, '*');
    };

    const obs = new IntersectionObserver((entries) => {
      entries.forEach(e => {
        if (e.isIntersecting) {
          e.target.classList.add('visible');
          obs.unobserve(e.target);
        }
      });
    }, { threshold: 0.12, rootMargin: '0px 0px -40px 0px' });

    document.querySelectorAll('.tl-item, .colors-text, .color-swatch').forEach(el => obs.observe(el));

    window.addEventListener('load', resizeEmbed);
    window.addEventListener('resize', resizeEmbed);
    setTimeout(resizeEmbed, 250);
    setTimeout(resizeEmbed, 1000);
  </script>
</body>

</html>
